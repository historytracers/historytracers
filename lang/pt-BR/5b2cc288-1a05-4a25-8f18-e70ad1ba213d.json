                        "month": "",
                        "day": ""
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": "."
            },
            {
               "text": "Além da evidência material, modelos de expansão genética mostram que poderia ter ocorrido uma única população migratória que se expandiu pelo continente (<htcite0>).",
               "source": [
                  {
                     "type": 0,
                     "uuid": "94372b4a-825c-4b76-a252-625274cb17b4",
                     "text": "Fagundes, N. J. R. et al.",
                     "page": "pp. 587 - 589",
                     "date_time": {
                        "type": "gregory",
                        "year": "2008",
                        "month": "",
                        "day": ""
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "markdown",
               "PostMention": "."
            },
            {
               "text": "<p><center><div class=\"first_steps_reflection_parent\"><div class=\"first_steps_reflection question_mark\"><i class=\"fa-solid fa-brain\"></i></div><div class=\"first_steps_reflection\"><b>Reflexão 3: Tudo resolvido?</b><br /><br />Temos um modelo arqueológico que possui dados coletados em diferentes partes do continente.<br /><br />Temos um modelo genético que mostra ser possível a ocorrência de apenas uma migração por todo o continente.<br /><br />Logo, concluímos que, se juntarmos os dois, resolveremos todas as questões sobre a chegada dos humanos à <i>Abya Yala</i> (América).<br /><br />Você consegue imaginar cenários que poderiam tornar a última conclusão inválida?</div></div></center></p>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": "."
            }
