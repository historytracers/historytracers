                                         "text":  "<p class=\"desc\"><img id=\"imgGeo24\" onclick=\"htImageZoom('imgGeo24', '0%')\" src=\"\" class=\"imgcenter\"/><b>Figura 1</b>: Neste mapa, o continente está destacado</p>",
                                         "source":  [
                                                        {
                                                            "type":  1,
                                                            "uuid":  "2be849f1-551b-44eb-8fc6-87027dbf8a68",
                                                            "text":  "Mounier, A., & Mirazón Lahr, M.",
                                                            "page":  "",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "2024",
                                                                              "month":  "",
