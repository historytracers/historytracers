            {
               "id": "exercise_v2",
               "text": [
                  {
                     "question": "O estudo de história das famílias é milenar?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "O estudo no Ocidente é recente, tendo começado apenas no século XIX."
                  },
                  {
                     "question": "O modelo de família em alguns povos de América (<i>Abya Yala</i>) era diferente do monogâmico?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "Diferentes crônicas mostram que não havia monogamia entre alguns povos indígenas. É importante ressaltar que isso não indica atraso, apenas uma cultura diferente."
                  },
                  {
                     "question": "Morgan concluiu que houve quatro tipos de famílias?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "Como apresentado no texto, na publicação de Frederick Engels somos apresentados a quatro tipos de famílias de acordo com Morgan."
                  },
                  {
                     "question": "Mulheres possuíam um papel maior nas famílias indígenas?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "Em diversas culturas, é possível encontrar mulheres em posições de destaque."
                  },
                  {
                     "question": "O processo de classificação de espécies começou apenas com Charles Darwin?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "Charles Darwin nos mostrou como os seres vivos mudam ao longo do tempo, mas o processo de classificação de espécies é anterior a ele."
                  },
                  {
                     "question": "O método taxonômico tem apenas uma etapa?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "A taxonomia de uma espécie representa um possível caminho de evolução ao longo de bilhões de anos, portanto, não é possível limitá-la a apenas uma etapa."
                  },
                  {
                     "question": "Os grupos da taxonomia não possuem hierarquia?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "Os grupos taxonômicos são hierarquizados, começando pelos mais abrangentes (Domínio) até os menos abrangentes (Espécie)."
                  },
                  {
                     "question": "O <b>Domínio</b> é o grupo taxonômico mais abrangente?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "O Domínio é o primeiro de todos os grupos, sendo o mais abrangente."
                  },
                  {
                     "question": "Toda espécie deve obrigatoriamente fazer parte de oito grupos taxonômicos que também indicam sua evolução ocorreu?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "Ao classificar uma espécie, ela deve fazer parte de todos os níveis hierárquicos para que possamos mapear sua evolução de forma completa."
                  }
               ]
            },
