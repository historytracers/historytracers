                                                                              "year":  "",
                                                                              "month":  "",
                                                                              "day":  ""
                                                                          }
                                                        },
                                                        {
                                                            "type":  1,
                                                            "uuid":  "08ac929b-a863-4a22-b7ed-ca86966b7b10",
                                                            "text":  "Cartwright, M.",
                                                            "page":  "Reconquista",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "2018",
                                                                              "month":  "10",
                                                                              "day":  "05"
                                                                          }
                                                        }
                                                    ],
                                         "date_time":  null,
                                         "isTable":  false,
                                         "imgdesc":  "",
                                         "format":  "html",
                                         "PostMention":  "."
                                     },
                                     {
                                         "text":  "Recentemente, alguns estudos e discussões em fóruns históricos têm sugerido possíveis conexões dos Banu Qasi com futuros monarcas da Península Ibérica ou até mesmo com o profeta Maomé. No entanto, até o momento, fontes primárias que sustentem essas hipóteses aparentemente não foram encontradas",
