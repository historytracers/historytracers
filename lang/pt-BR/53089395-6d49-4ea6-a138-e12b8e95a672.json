         "text": [
            {
               "text": "<p class=\"desc\"><img id=\"imgGeo21\" onclick=\"htImageZoom('imgGeo21', '0%')\" src=\"\" class=\"imgcenter\"/><b>Figura 1</b>: Neste mapa, o continente está destacado © Mapswire (<htcite0>)</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "dd4f3c8a-6624-4df5-93ac-37e0a4be9fdc",
                     "text": "Mapswire",
                     "page": "",
                     "date_time": {
                        "type": "",
