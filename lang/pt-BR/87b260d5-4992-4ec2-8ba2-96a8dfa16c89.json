                     "year": "2024",
                     "month": "-1",
                     "day": "-1"
                  },
                  {
                     "type": "gregory",
                     "year": "2017",
                     "month": "6",
                     "day": "13"
                  }
               ],
               "isTable": false,
               "imgdesc": "Nessa imagem, vemos um indígena segurando um quipu (cordas com nós), com um valor numérico indicado à direita. À esquerda, há uma Yupana—um tabuleiro com pontos que representam números, possivelmente associados aos nossos dedos.",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p>Nesse sistema, a ausência de um nó representa o número zero (0), e cada número adicional é indicado por um nó, ou volta, até o limite de nove (9). Quando esse limite é alcançado, os nós são feitos em uma posição superior (<htcite0>):</p><p class=\"desc\"><img id=\"imgAndesQuipu\" onclick=\"htImageZoom('imgAndesQuipu', '0%')\" class=\"imgcenter\"/><b>Figura 3</b>: Representação de um quipu. Código-fonte presente no GitHub do projeto (<htcite1>).</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "6e9bef8c-6ec5-4c04-b583-aea8e6bbec5b",
                     "text": "Quesada, Eugenio de",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "2016",
                        "month": "08",
                        "day": "04"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "240800f3-ede4-4deb-9d4e-915a3a03fa68",
                     "text": "History Tracers Team",
                     "page": "Código-fonte",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "05",
                        "day": "30"
                     }
                  }
               ],
               "date_time": [
                  {
                     "type": "gregory",
                     "year": "2016",
                     "month": "-1",
                     "day": "-1"
                  },
                  {
                     "type": "gregory",
                     "year": "2024",
                     "month": "-1",
                     "day": "-1"
                  }
               ],
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p><h4>A Yuapana</h4>O método <i>\"Yupana Inka Tawa Pukllay\"</i>, utilizado nesta página, foi desenvolvido e publicado por Dhavit Prem (<htcite0>) da Associação Yupanki (<htcite1>). Esse método segue o modelo vertical da <i>Yupana</i>, conforme apresentado no trabalho de Felipe Guaman Poma de Ayala (<htcite2>). Quando o limite de nove (9) é atingido, os valores começam a ser registrados na linha superior:</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "2d2ea4a5-506b-4dbf-aaa4-3a10a8fbbd9c",
                     "text": "Prem, Dhavit",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "2018",
                        "month": "07",
                        "day": "25"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "a62b520a-f443-4d83-ab51-b99c9a46dab8",
                     "text": "Prem, Dhavit",
                     "page": "pp. 354 - 363",
                     "date_time": {
                        "type": "gregory",
                        "year": "2018",
                        "month": "04",
                        "day": "01"
                     }
                  },
                  {
                     "type": 0,
                     "uuid": "f5b74f18-0bc4-46d2-8a5c-64dd80b74dd1",
                     "text": "Poma de Ayala, Felipe Guaman",
                     "page": "pp. 361 - 362",
                     "date_time": {
                        "type": "gregory",
                        "year": "1615",
                        "month": "02",
                        "day": "13"
                     }
                  }
               ],
               "date_time": [
                  {
                     "type": "gregory",
                     "year": "2018",
                     "month": "-1",
                     "day": "-1"
                  },
                  {
                     "type": "gregory",
                     "year": "1615",
                     "month": "-1",
                     "day": "-1"
                  }
