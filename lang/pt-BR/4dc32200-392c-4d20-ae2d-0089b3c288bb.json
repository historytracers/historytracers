   "exercise_v2": [
      {
         "question": "Em ambos os ábacos, Soroban e Suanpan (算盤), as ordens numéricas são representados na vertical?",
         "yesNoAnswer": "No",
         "additionalInfo": "Apesar de representarmos a contagem na vertical, quando falamos das ordens numéricas (unidade, dezena, centena...), elas são representadas na horizontal."
      },
      {
         "question": "O marcador na barra horizontal representa a posição que olhamos a maior ordem?",
         "yesNoAnswer": "No",
         "additionalInfo": "O marcador na barra horizontal nos mostra o local da menor orderm, ou seja, a unidade."
      }
