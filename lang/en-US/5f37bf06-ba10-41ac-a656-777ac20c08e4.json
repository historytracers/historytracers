      {
         "text": "<p><img id=\"imgHr0\" onclick=\"htImageZoom('imgHr0', '0%')\" src=\"images/DonsMaps/img_6647rudolfensis.jpg\" class=\"imgcenter\"/></p><p class=\"desc\"><b>Figure 2</b>: Reconstruction of the <i>Homo rudolfensis</i>. © Don Hitchcock. Original at the <i>Vienna Natural History Museum</i> (<htcite0>).</p>",
         "source": [
            {
               "type": 1,
               "uuid": "de46261a-f4ef-4dc5-b5ae-f2afe319858c",
