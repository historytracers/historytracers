         "text": [
            {
               "text": "<p class=\"desc\"><img id=\"imgPlanetSpaceTime\" onclick=\"htImageZoom('imgPlanetSpaceTime', '0%')\" src=\"\" class=\"imgcenter\"/><b>Figure 1</b>: Illustration of gravity as the curvature of spacetime (<htcite0>).</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "7d122568-047f-4d87-a003-ddbd62245955",
                     "text": "History Tracers Team",
                     "page": "images/HistoryTracers/Planet_Space_Time.png",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "",
                        "day": ""
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
