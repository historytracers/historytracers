            {
               "text": "<p class=\"desc\"><img class=\"imgcenter\" src=\"images/Mapswire/world-physical-map-graticules-mercator-v1.jpg\" id=\"imgWest\" onclick=\"htImageZoom('imgWest', '0%')\"/><b>Figure 2</b>: Mercator projection. © Mapswire (<i><htcite0></i>). Shared under the <a href=\"https://whc.unesco.org/en/licenses/6\" target=\"_blank\">Creative Commons Attribution-ShareAlike 3.0 IGO</a> license.</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "dd4f3c8a-6624-4df5-93ac-37e0a4be9fdc",
                     "text": "Mapswire",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "",
