                     }
                  },
                  {
                     "type": 1,
                     "uuid": "9828a108-dfdf-4692-a819-18b690d4a629",
                     "text": "Raikar, S.P.",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "2025",
                        "month": "12",
                        "day": "22"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "9828a108-dfdf-4692-a819-18b690d4a629",
                     "text": "Raikar, S.P.",
                     "page": "",
                     "date_time": {
