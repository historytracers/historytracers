            {
               "text": "<p><table class=\"mesoamerican\"><tr><th>Mesoamerican Number</th><th>Decimal Number</th><th>Control</th></tr> <tr><td><img src=\"\" id=\"tmc1l1\" onclick=\"htImageZoom('tmc1l1', '0%')\" /></td><td id=\"tmc2l1\" rowspan=\"10\"><span class=\"text_to_paint_small\" id=\"mesoIndoArabic\">0</span></td><td rowspan=\"10\"><input type=\"text\" id=\"mesoValue\" value=\"10135975700986\" style=\"font-size:2vh;\" size=\"14\" /><i class=\"fa-solid fa-play\" style=\"color: Tomato;font-size: 5.0em\" name=\"meso\"></i></td></tr> <tr><td><img src=\"\" id=\"tmc1l2\" onclick=\"htImageZoom('tmc1l2', '0%')\" /></td> <tr><td><img src=\"\" id=\"tmc1l3\" onclick=\"htImageZoom('tmc1l3', '0%')\" /></td></tr></tr> <tr><td><img src=\"\" id=\"tmc1l4\" onclick=\"htImageZoom('tmc1l4', '0%')\" /></td></tr></tr> <tr><td><img src=\"\" id=\"tmc1l5\" onclick=\"htImageZoom('tmc1l5', '0%')\" /></td></tr></tr> <tr><td><img src=\"\" id=\"tmc1l6\" onclick=\"htImageZoom('tmc1l6', '0%')\" /></td></tr></tr> <tr><td><img src=\"\" id=\"tmc1l7\" onclick=\"htImageZoom('tmc1l7', '0%')\" /></td></tr></tr> <tr><td><img src=\"\" id=\"tmc1l8\" onclick=\"htImageZoom('tmc1l8', '0%')\" /></td></tr></tr> <tr><td><img src=\"\" id=\"tmc1l9\" onclick=\"htImageZoom('tmc1l9', '0%')\" /></td></tr></tr> <tr><td><img src=\"\" id=\"tmc1l10\" onclick=\"htImageZoom('tmc1l10', '0%')\" /></td></tr></tr></table></p>",
