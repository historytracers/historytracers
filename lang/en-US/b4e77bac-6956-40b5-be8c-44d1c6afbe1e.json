                  {
                     "text": "<p class=\"desc\"><img id=\"imgCylinder\" onclick=\"htImageZoom('imgCylinder', '0%')\" src=\"images/BritishMuseum/mid_00262857_001.jpg\" class=\"imgcenter\"/><b>Figure 2</b>: Cyrus Cylinder. © Trustees of the British Museum (<a href=\"#\" onclick=\"htCleanSources(); htFillPrimarySource('73cc1d07-b9c6-4c6d-894d-17cdf822bc44'); return false;\"><i>The British Museum</i></a> ).</p>",
                     "source": null,
