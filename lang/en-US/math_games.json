         "html_value": null,
         "source": null,
         "value": [
            {
               "family_id": "",
               "person_id": "",
               "id": "e434ae19-4f25-4880-8227-0970cd27ccb6",
               "name": "Building to count (Soroban, 算盤)",
               "desc": "In this text, we explore how we can count using a Japanese instrument.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "716d6fe5-78cc-4fef-85da-11daff12399d",
               "name": "Building to count (Suanpan, 算盤)",
               "desc": "In this text, we see the differences and what is in common between the Chinese abacus and the Japanese abacus.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "4dc32200-392c-4d20-ae2d-0089b3c288bb",
               "name": "Higher orders with Soroban and Suanpan (算盤)",
               "desc": "In this text, we learn how to represent orders higher than the units in the different versions of the abacus.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "ba340a77-cf71-4471-8e4c-43afa358833b",
               "name": "Adding with Soroban and Suanpan (算盤)",
               "desc": "In this text, we learn how to add with tools developed in Asia.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "6d9857d3-a1af-4411-b358-b97a7ea02515",
               "name": "Adding with Soroban and Suanpan (算盤) — Part 2",
               "desc": "We learned to add with the abacuses when the numbers have higher orders.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "f91d9720-3085-4e71-ae5d-7e7cf6b7b7b2",
               "name": "Practicing addition with Soroban and Suanpan (算盤)",
               "desc": "In this text, we present an application that instructs people, step by step, on how to perform an addition using these abacuses.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "8bf96824-262d-4a55-bd39-2dbb887c1dc0",
               "name": "Multiplying with Soroban and Suanpan (算盤)",
               "desc": "In this text, we visualize how multiplication can be represented through repeated addition using the abacus.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "2836521c-6ddd-4fb9-a78d-b1b12db94883",
               "name": "Soroban and Suanpan (算盤) in rereading",
               "desc": "In this text, we use the rereading of numbers together with the abacuses to assist in performing multiplications with larger numbers.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "2bf58492-72be-4fbc-99b4-a0a3d4a0df31",
               "name": "Soroban and Suanpan (算盤): multiplication in practice",
               "desc": "An app to reinforce multiplication knowledge.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "078f3c4e-08fc-454c-8510-1a98a7e45a40",
               "name": "Practicing multiplication with Soroban and Suanpan (算盤)",
               "desc": "In this app, multiplying one number by another is taken to the next level.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "052bd667-eb38-4e87-8c05-439cfd9c4178",
               "name": "Multiplying without barriers with Soroban and Suanpan (算盤)",
               "desc": "In this text, once again, we use an app to understand how to perform any multiplication.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "954d7638-3994-4c9b-a075-b2f9b343a098",
               "name": "Subtracting with Soroban and Suanpan (算盤)",
               "desc": "In this text, we learn how to perform subtraction using complements on the abacus.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "e4103f19-1efb-469f-bd69-d44d43e0d3a3",
               "name": "Practicing subtraction with the Soroban and the Suanpan (算盤)",
               "desc": "we present an app that teaches, step by step, how to perform subtractions using these abacuses.",
               "date_time": null
            }
         ],
         "date_time": null
      },
