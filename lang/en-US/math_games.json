         "page": "class_content",
         "value_type": "group-list",
         "html_value": null,
         "source": null,
         "value": [
            {
               "family_id": "",
               "person_id": "",
               "id": "687ee328-19bb-4a65-ab46-7d707a2e11dc",
               "name": "Drawing to count",
               "desc": "Exploring how indigenous peoples developed methods for counting.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "87b260d5-4992-4ec2-8ba2-96a8dfa16c89",
               "name": "Change of direction (Part I)",
               "desc": "We study the logic behind the different approach used by indigenous communities as their numbers grow..",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "323c97e8-1153-4ab8-8c41-0ca26225fe20",
               "name": "Change of direction (Part II)",
               "desc": "Building on the previous discussion, this section explores how indigenous peoples represent large numbers.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "c742c649-bf12-4d3f-ba8c-52f91455fc95",
               "name": "Yupana (Addition)",
               "desc": "Using the <i>Yupana Inka Tawa Pukllay</i>, method, developed by Dhavit Prem (<a href=\"#\" onclick=\"htCleanSources(); htFillReferenceSource('a62b520a-f443-4d83-ab51-b99c9a46dab8'); return false;\">Prem, Dhavit</a>), addition is presented in a visual way",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "b0bb8da3-ca00-453e-9060-9dfa767c80e2",
               "name": "Practicing with the Yupana (Addition)",
               "desc": "In this text, we use the knowledge acquired from the previous text to perform additions with the Yupana.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "9a7a978b-3fac-422c-8e41-3ef1a24e88f3",
               "name": "Yupana (Multiplication)",
               "desc": "Using the same method (<a href=\"#\" onclick=\"htCleanSources(); htFillReferenceSource('a62b520a-f443-4d83-ab51-b99c9a46dab8'); return false;\">Prem, Dhavit</a>), multiplication is also presented visually.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "f17ec53f-af65-4708-bcc1-a140287d4dd9",
               "name": "Subtracting with the Yupana",
               "desc": "In this text, we learn how to perform subtractions using the Inca Yupana.",
               "date_time": null
            }
         ],
         "date_time": null
      },
