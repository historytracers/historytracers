            {
               "family_id": "",
               "person_id": "",
               "id": "f6587eb2-c0db-4ce0-bed7-901835116466",
               "name": "Hands and music",
               "desc": "In this text, with the help of the music produced by our hands, we reinforce the understanding of counting from 0 to 10.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "ef299aac-2abd-4fac-9974-05e697639b20",
               "name": "Walking and singing",
               "desc": "Who was the first person in the family to walk? What is the relationship of this to indigenous numbers?",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "48f8f1cd-5036-4140-aafc-697963fe5dfb",
               "name": "Exercising with numbers",
               "desc": "We do a physical exercise with the numbers to reinforce the addition of units and tens.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "59648475-3d23-45fe-8d6e-f3def1a2729b",
               "name": "Multiplying with the body (Level 1)",
               "desc": "In this text, we deepen our knowledge about the evolution of human beings, in addition to multiplying using our own bodies.",
               "date_time": null
            },
            {
               "family_id": "",
               "person_id": "",
               "id": "c4b96e7c-627b-46d0-820c-409a1e9f47b8",
               "name": "Multiplying with the body (Level 2)",
               "desc": "Continuando con la multiplicación con nuestro cuerpo, aprendimos que no somos los únicos animales que creamos rituales a lo largo de la evolución.",
               "date_time": null
            }
         ],
         "date_time": null
