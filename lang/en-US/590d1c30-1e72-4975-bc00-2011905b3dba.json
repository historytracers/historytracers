      {
         "id": "SECTION_prerequisites",
         "text": [
            {
               "text": "<p><span id=\"htZoomImageMsg\"></span></p>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p><h3>Prerequisites</h3>The text on this page aims to reinforce knowledge of indigenous numerical systems and the numbers we use today. Before starting, we suggest studying the following previous pages:</p><p><ul><li><htcite0>: in this first text, we show for people their body symmetry.</li> <li><htcite1>: we introduce the idea of counting using our body.</li> <li><htcite2>: exploring the limitations and the necessity of new tools to count.</li></ul></p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "20b14681-88c0-438a-a273-a0902ae5db38",
                     "text": "History Tracers Team",
                     "page": "Our sides are equal",
                     "date_time": {
                        "type": "gregory",
                        "year": "2023",
                        "month": "05",
                        "day": "30"
                     }
                  },
                  {
                     "type": 1,
