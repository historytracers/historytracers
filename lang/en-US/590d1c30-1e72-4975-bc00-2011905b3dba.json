                     "text": "History Tracers Team",
                     "page": "Couting",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "06",
                        "day": "12"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "cc8c1467-a6af-4f9c-ba60-ab6df35aba05",
                     "text": "History Tracers Team",
