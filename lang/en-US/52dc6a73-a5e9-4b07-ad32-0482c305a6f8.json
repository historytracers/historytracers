   "content": [
      {
         "id": "SECTION_prerequisites",
         "text": [
            {
               "text": "<p><span id=\"htZoomImageMsg\"></span></p>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p><h3>Prerequisites</h3>The game on this page aims to reinforce knowledge of indigenous numerical systems and the numbers we use today. Before starting, we suggest studying the following previous pages:</p><p><ul><li><htcite0>: in this first text, we show for people their body symmetry.</li> <li><htcite1>: we introduce the idea of counting using our body.</li> <li><htcite2>: exploring the limitations and the necessity of new tools to count.</li></ul></p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "20b14681-88c0-438a-a273-a0902ae5db38",
                     "text": "History Tracers Team",
                     "page": "Our sides are equal",
                     "date_time": {
                        "type": "gregory",
                        "year": "2023",
                        "month": "05",
                        "day": "30"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "3874d1e8-0f76-4432-9ee2-d8c8c9dccf53",
                     "text": "History Tracers Team",
                     "page": "Couting",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "06",
                        "day": "12"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "cc8c1467-a6af-4f9c-ba60-ab6df35aba05",
                     "text": "History Tracers Team",
                     "page": "Beyond fingers",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "07",
                        "day": "23"
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            }
         ]
      },
      {
         "id": "SECTION_rules",
         "text": [
            {
               "text": "<p><h3>General rules</h3>The squares with question marks contain different images. Your goal is to find matching pairs of images. Each time you find a pair, the number of pairs found will be updated on the right side. When all pairs are found, you will receive two medals (<i class=\"fa-solid fa-medal\" style=\"color:gold;\"></i> <i class=\"fa-solid fa-medal\" style=\"color:gold;\"></i>).</p>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            }
         ]
      },
      {
         "id": "SECTION_game",
         "text": [
            {
               "text": "<p><h3>Memory game</h3>When you complete the game, you can restart it by clicking the button <input id=\"playButton\" type=\"button\" />.</p>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p><table id=\"yupana0\" class=\"tawapukllay\"><tr><th colspan=\"4\">Memory Game</th><th>Counting</th><th colspan=\"2\">Representation</th></tr> <tr id=\"tf1\"><td id=\"tc1f1\"></td> <td id=\"tc2f1\"></td> <td id=\"tc3f1\"></td> <td id=\"tc4f1\"></td> <td id=\"tc5f1\">Hands<td id=\"tc6f1\">&nbsp;</td><td id=\"tc7f1\">&nbsp;</td></tr> <tr id=\"tf2\"><td id=\"tc1f2\"></td> <td id=\"tc2f2\"></td> <td id=\"tc3f2\"></td> <td id=\"tc4f2\"></td><td id=\"tc5f2\" rowspan=\"2\">Indigenous</td><td id=\"tc6f2\" rowspan=\"2\" colspan=\"2\">&nbsp;</td></tr> <tr id=\"tf3\"><td id=\"tc1f3\"></td> <td id=\"tc2f3\"></td> <td id=\"tc3f3\"></td> <td id=\"tc4f3\"></td></tr> <tr id=\"tf4\"><td id=\"tc1f4\"></td> <td id=\"tc2f4\"></td> <td id=\"tc3f4\"></td> <td id=\"tc4f4\"></td><td id=\"tc5f4\" rowspan=\"2\">Hindu-Arabic</td><td id=\"tc6f4\" rowspan=\"2\" colspan=\"2\">&nbsp;</td></tr> <tr id=\"tf5\"></td> <td id=\"tc1f5\"></td> <td id=\"tc2f5\"></td> <td id=\"tc3f5\"></td> <td id=\"tc4f5\"></td></tr></table>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p class=\"desc\">We work with <i>Yupana</i> using the <i>\"Yupana Inka Tawa Pukllay\"</i> method, developed and published by Dhavit Prem (<htcite0>) of the Yupanki Association (<htcite1>).<br />The use of Mesoamerican numbers is based on the work of Orlando Josué Casares Contreras, José M. Gamboa Cetina y Venus Sarahí Estrella Cabrera (<htcite2> ; <htcite3>). Additionally, we incorporate the work of Francisco Barriga Puente, and Ximena Catepillán (<htcite4> ; <htcite5>).<br /> Finally, we utilize various counting methods inspired by the work of Francisco A. González Redondo <i>et al.</i> (<htcite6>).<br />The game's source code was inspired by code available on CodePen (<htcite7>).</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "2d2ea4a5-506b-4dbf-aaa4-3a10a8fbbd9c",
                     "text": "Prem, Dhavit",
