                                         "PostMention":  ""
                                     },
                                     {
                                         "text":  "<p class=\"desc\"><img class=\"imgcenter\" src=\"images/UNESCO/site_0364_0028-1000-750-20250313170037.jpg\" id=\"imgWALL\" onclick=\"htImageZoom('imgWALL', '0%')\"/><b>Figure 2</b>: Great Zimbabwe National Monument (<a href=\"#\" onclick=\"htCleanSources(); htFillReferenceSource('19934031-f0f5-4a1d-83c3-6391b5acaff8'); return false;\">The National Museum and Monuments of Zimbabwe</a>). Photo taken by Erik Eschweiler-Dienerowitz and made available on the UNESCO website (<a href=\"#\" onclick=\"htCleanSources(); htFillReferenceSource('b7d68d4b-67a9-4624-9ce6-9b0e2f01c50e'); return false;\">UNESCO</a>). Shared under the <a href=\"https://whc.unesco.org/en/licenses/6\" target=\"_blank\">Creative Commons Attribution-ShareAlike 3.0 IGO</a> license.</p>",
                                         "source":  [

                                                    ],
                                         "date_time":  null,
                                         "isTable":  false,
                                         "imgdesc":  "",
                                         "format":  "html",
                                         "PostMention":  "."
                                     },
                                     {
                                         "text":  "Since we already have an expository text about Great Zimbabwe on *History Tracers* (<htcite0>), in the atlas we will focus on some reflections about the Shona trade with the Chinese during **Phase 3** (<htdate0>/<htdate1> - <htdate2>/<htdate3>) of the appearance of ceramics in East Africa, as mentioned in the work of Dr. Bing Zhao (<htcite1>; <htcite2>).",
                                         "source":  [
                                                        {
                                                            "type":  1,
                                                            "uuid":  "0c717575-d51a-464d-9be6-8ecfda771376",
                                                            "text":  "History Tracers Team",
                                                            "page":  "Great Zimbabwe",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "2025",
                                                                              "month":  "",
                                                                              "day":  ""
                                                                          }
                                                        },
                                                        {
                                                            "type":  1,
                                                            "uuid":  "f7381734-81dc-4bef-8527-44317f40c4b4",
                                                            "text":  "Zhao, B.",
                                                            "page":  "",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "2015",
                                                                              "month":  "",
                                                                              "day":  ""
                                                                          }
                                                        },
                                                        {
                                                            "type":  1,
                                                            "uuid":  "0c717575-d51a-464d-9be6-8ecfda771376",
                                                            "text":  "History Tracers Team",
                                                            "page":  "Great Zimbabwe",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "2025",
                                                                              "month":  "",
                                                                              "day":  ""
                                                                          }
                                                        }
                                                    ],
                                         "date_time":  null,
                                         "isTable":  false,
