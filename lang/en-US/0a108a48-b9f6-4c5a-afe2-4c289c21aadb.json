                                     {
                                         "text":  "### Great Zimbabwe\n\nIn this map, we have Africa with a small red dot indicating the approximate location of Great Zimbabwe (<htcite0>; <htcite1>).",
                                         "source":  [
                                                        {
                                                            "type":  1,
                                                            "uuid":  "dd4f3c8a-6624-4df5-93ac-37e0a4be9fdc",
                                                            "text":  "Mapswire",
                                                            "page":  "",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "",
                                                                              "month":  "",
                                                                              "day":  ""
                                                                          }
                                                        },
                                                        {
                                                            "type":  1,
                                                            "uuid":  "19934031-f0f5-4a1d-83c3-6391b5acaff8",
                                                            "text":  "The National Museum and Monuments of Zimbabwe",
                                                            "page":  "",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "",
                                                                              "month":  "",
                                                                              "day":  ""
                                                                          }
                                                        }
                                                    ],
                                         "date_time":  null,
                                         "isTable":  false,
                                         "imgdesc":  "",
