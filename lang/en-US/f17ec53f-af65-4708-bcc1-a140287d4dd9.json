   "exercise_v2": [
      {
          "question": "On the Yupana, do we use the same movements as on the abacus to perform subtraction?",
         "yesNoAnswer": "No",
          "additionalInfo": "The movements are different because we represent numbers on the Yupana differently from how we do on abacuses."
      },
      {
          "question": "Is it correct to say that the Yupana is better than an abacus, or that an abacus is better than the Yupana for performing subtraction?",
         "yesNoAnswer": "No",
          "additionalInfo": "Although this question presents a conflict between the Yupana and the abacus, it highlights a broader issue: the coexistence of different perspectives. In itself, the question does not make much sense, since both the Yupana and the abacus allow us to perform the same mathematical operations, albeit through different movements. A person may prefer one tool over the other, but that does not mean one is better than the other."
      }
