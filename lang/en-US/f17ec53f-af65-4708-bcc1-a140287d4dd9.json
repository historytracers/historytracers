                        "year": "2024",
                        "month": "",
                        "day": ""
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "markdown or html",
               "PostMention": ""
            },
            {
               "text": "<p><center><div class=\"first_steps_reflection_parent\"><div class=\"first_steps_reflection question_mark\"><i class=\"fa-solid fa-brain\"></i></div><div class=\"first_steps_reflection\"><b>Reflexão 2: O reverso</b><br /><br />O que aconteceria se esses movimentos fossem realizados na ordem inversa?</div></div></center></p>",
               "source": null,
