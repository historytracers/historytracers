               "PostMention": ""
            },
            {
               "text": "<p><div class=\"htSlides\"><div class=\"htSlide\"><div class=\"htSlideCounter\">1 / 5</div><img class=\"imgGameSize\" id=\"ArmsMaertin\" onclick=\"htImageZoom('ArmsMaertin', '0%')\"><div class=\"htSlideCaption\">Arms of Maertim Lem (<htcite0>). <span id=\"ANTTPortugal2\"></span></div></div><div class=\"htSlide\"><div class=\"htSlideCounter\">2 / 5</div><img class=\"imgGameSize\" id=\"ArmsAntonio\" onclick=\"htImageZoom('ArmsAntonio', '0%')\"><div class=\"htSlideCaption\">Arms of Antonio Leme (<htcite1>). <span id=\"ANTTPortugal1\"></span></div></div><div class=\"htSlide\"><div class=\"htSlideCounter\">3 / 5</div><img class=\"imgGameSize\" id=\"PDPFamilyTree\" onclick=\"htImageZoom('PDPFamilyTree', '0%')\"><div class=\"htSlideCaption\">Genealogical tree attached to the diligence of Pedro Dias Paes (<htcite2>). <span id=\"ANTTPortugal3\"></span></div></div><div class=\"htSlide\"><div class=\"htSlideCounter\">4 / 5</div><img class=\"imgGameSize\" id=\"imgANTTINCOMPLETE\" onclick=\"htImageZoom('imgANTTINCOMPLETE', '0%')\"><div class=\"htSlideCaption\">Incomplete habilitation for the Order of Christ (<htcite3>). © Arquivo Nacional Torre do Tombo (<htcite4>).</div></div><div class=\"htSlide\"><div class=\"htSlideCounter\">5 / 5</div><img class=\"imgGameSize\" id=\"RP\" onclick=\"htImageZoom('RP', '0%')\"><div class=\"htSlideCaption\">Bula present in the Arquivo Nacional da Torre do Tombo, Lisboa, Portugal (<htcite5>).</div></div><i class=\"fa-solid fa-chevron-left htSlidePrev\" onclick=\"htPlusDivs(-1);\"></i><i class=\"fa-solid fa-chevron-right htSlideNext\" onclick=\"htPlusDivs(1);\"></i></div></p>",
