            },
            {
               "text": "<center><div class=\"first_steps_reflection_parent\" style=\"background-color: #FFFFFF;\"><div class=\"first_steps_reflection\" style=\"background-color: #FFFFFF;\"><p><math mathsize=\"1.5em\" displaystyle=\"false\"><mi>0</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>4</mi></math><br /> <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>8</mi></math><br /> <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>8</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>12</mi></math><br /><math mathsize=\"0.8em\" displaystyle=\"false\"><mo lspace=\"0.1667em\" rspace=\"0.1667em\">Retiramos 6 do 8 e complementamos o 4, fazendo: 2 + (4 + 6) = 12</mo></math><br /><br /> <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>12</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>16</mi></math><br />  <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>16</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>20</mi></math><br /><math mathsize=\"0.8em\" displaystyle=\"false\"><mo lspace=\"0.1667em\" rspace=\"0.1667em\">Retiramos 6 do 16 e complementamos o 4, fazendo: 10 + (4 + 6) = 20</mo></math><br /><br /> <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>20</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>24</mi></math><br /> <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>24</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>28</mi></math><br /> <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>28</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>32</mi></math><br /><math mathsize=\"0.8em\" displaystyle=\"false\"><mo lspace=\"0.1667em\" rspace=\"0.1667em\">Retiramos 6 do 28 e complementamos o 4, fazendo: 22 + (4 + 6) = 32</mo></math><br /><br /><math mathsize=\"1.5em\" displaystyle=\"false\"><mi>32</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>36</mi></math><br />  <math mathsize=\"1.5em\" displaystyle=\"false\"><mi>36</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mi>4</mi><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mi>40</mi></math><br /><math mathsize=\"0.8em\" displaystyle=\"false\"><mo lspace=\"0.1667em\" rspace=\"0.1667em\">Retiramos 6 do 36 e complementamos o 4, fazendo: 30 + (4 + 6) = 40</mo></math>  </p><p class=\"desc\"><b>Cálculo 1</b>: Soma consecutiva do número 4 com comentários.</p></div></div></center>",
