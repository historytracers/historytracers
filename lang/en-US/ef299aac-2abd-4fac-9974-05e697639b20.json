            },
            {
               "text": "<div class=\"controls\"><label>Number of claps, steps, or jumps:</label> <select id=\"clapCount\"></select>  <i class=\"fa-solid fa-hands-clapping\" onclick=\"startClap()\" style=\"font-size:2em;color:#0f0;\" ></i> <i class=\"fa-solid fa-person-walking\" onclick=\"startSteps()\" style=\"font-size:2em;color:#f00;\" ></i> <i class=\"fa-solid fa-person-running\" onclick=\"startJump()\" style=\"font-size:2em;color:#00f;\" ></i> <div class=\"speed-control\"> <label>Devagar</label> <input type=\"range\" id=\"speedSlider\" min=\"600\" max=\"1600\" value=\"1100\" step=\"10\" style=\"direction: rtl;\"> <label>Rápido</label> <span style=\"font-size: 1em;\">Claps:</span> <div id=\"clapCounter\" style=\"font-size: 1em;\">0 / 0</div> <span style=\"font-size: 1em;\">Steps:</span> <div id=\"stepsCounter\" class=\"counter\" style=\"font-size: 1em;\">0 / 0</div>  <span style=\"font-size: 1em;\">Jumps:</span> <div id=\"jumpCounter\" class=\"counter\" style=\"font-size: 1em;\">0 / 0</div></div> </div><div class=\"palette\" id=\"palette\"></div>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
