                     "day": "-1"
                  }
               ],
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p>Finally, it is necessary to make a caveat regarding the <i>Popol Vuh</i>. Although it portrays the beliefs of the K'iche' Maya prior to the arrival of the colonizers, a detailed analysis indicates that parts of the text may contain Christian influences (<htcite0> ; <htcite1>).</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "85cb27e2-5854-456d-9a0a-2123fa5c0975",
                     "text": "Mark, J. J.",
                     "page": "Popol Vuh",
                     "date_time": {
                        "type": "gregory",
                        "year": "2014",
                        "month": "10",
                        "day": "29"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "0fe64269-28a5-4f86-a0a2-aaf78619183f",
                     "text": "Dourado, Miguel R.",
