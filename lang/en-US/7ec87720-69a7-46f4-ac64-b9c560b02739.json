      {
         "id": "SECTION_prerequisites",
         "text": [
            {
               "text": "<p><span id=\"htZoomImageMsg\"></span></p><p><span id=\"htAmericaAbyaYalaMsg\"></span> (<htcite0>).</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "160fb48c-1711-491e-a1aa-e1257e7889af",
                     "text": "Porto-Gonçalves, Carlos Walter,",
                     "page": "pp. 39-43",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "05",
                        "day": "11"
                     }
                  }
               ],
               "date_time": [
                  {
                     "type": "gregory",
                     "year": "2011",
                     "month": "-1",
                     "day": "-1"
                  }
               ],
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "<p><h3>Prerequisites</h3>The game on this page aims to reinforce knowledge of indigenous numerical systems and the numbers we use today. Before starting, we suggest studying the following previous pages:</p><p><ul><li><htcite0>: in this first text, we show for people their body symmetry.</li> <li><htcite1>: we introduce the idea of counting using our body.</li> <li><htcite2>: exploring the limitations and the necessity of new tools to count.</li></ul></p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "20b14681-88c0-438a-a273-a0902ae5db38",
                     "text": "Our sides are equal",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "2025",
                        "month": "05",
                        "day": "30"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "3874d1e8-0f76-4432-9ee2-d8c8c9dccf53",
                     "text": "Couting",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "06",
                        "day": "12"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "cc8c1467-a6af-4f9c-ba60-ab6df35aba05",
                     "text": "Beyond fingers",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "06",
                        "day": "12"
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            }
