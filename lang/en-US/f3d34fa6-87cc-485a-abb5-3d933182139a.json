            {
               "id": "exercise_v2",
               "text": [
                  {
                     "question": "Is the study of family history ancient?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "Research in the Western world is relatively recent, having begun only in the 19th century."
                  },
                  {
                     "question": "Is the family model in America (<i>Abya Yala</i>) different from monogamy?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "Different chronicles show that monogamy was not present in various Indigenous cultures. We emphasize that this is not an indication of primitiveness but rather a reflection of cultural diversity."
                  },
                  {
                     "question": "Did Morgan conclude that there are four types of families?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "As shown in the text, Frederick Engels' work presents four different types of families according to Morgan."
                  },
                  {
                     "question": "Do women play a significant role in indigenous families?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "In various cultures, it is possible to find women in prominent positions."
                  },
                  {
                     "question": "Does the species classification process begin with Charles Darwin?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "Charles Darwin showed us how living beings change over time, but the classification process predates him."
                  },
                  {
                     "question": "Does the taxonomic method consist of only one step?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "The taxonomy of a species represents the entire possible evolutionary path of that species over billions of years, so it cannot be reduced to a single step."
                  },
                  {
                     "question": "Do the taxonomy groups have no hierarchy?",
                     "yesNoAnswer": "No",
                     "additionalInfo": "Taxonomical groups are hierarchical, starting with the largest group (Domain) and ending with the smallest group (Species)."
                  },
                  {
                     "question": "Is <b>Domain</b> the largest taxonomic group?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "The Domain is the first and largest of all groups."
                  },
                  {
                     "question": "Is it mandatory for all species to belong to all eight taxonomic groups that also demonstrate their evolutionary steps?",
                     "yesNoAnswer": "Yes",
                     "additionalInfo": "When classifying a species, it must be placed within all hierarchical levels to create an accurate map of its evolution."
                  }
               ]
            },
