                              "year": "2006",
                              "month": "",
                              "day": ""
                           }
                        },
                        {
                           "type": 1,
                           "uuid": "5ffa36cb-1d69-4a58-ab2d-7160118425dd",
                           "text": "Wright, A.F.",
                           "page": "Wendi",
                           "date_time": {
                              "type": "gregory",
                              "year": "2026",
                              "month": "01",
                              "day": "01"
                           }
                        }
                     ],
                     "date_time": [
                        {
