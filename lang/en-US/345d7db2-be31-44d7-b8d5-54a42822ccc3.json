                                         "text":  "<center><div class=\"htCircle\" style=\"height: 40vh; width: 40vh; background-color: white; border:1px solid black;\" name=\"fig2\"></div></center><p class=\"desc\"><b>Figure 2</b>: Circle representing the contraction of the universe.</p><script>var divRadius = parseInt($(\".htCircle[name='fig2']\").width()); $(\".htCircle\").mouseenter(function(){ $(this).animate({ width: divRadius/4, height: divRadius/4 }, 'slow'); }).mouseleave(function(){ $(this).animate({ width: divRadius, height: divRadius }, 'slow'); });</script>",
