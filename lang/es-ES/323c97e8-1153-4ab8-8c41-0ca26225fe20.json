            {
               "text": "<p><table id=\"yupana2\" class=\"tawapukllay\"> <tr><th>Rey (<i>Ajaw</i>)</th><th>Generación</th><th>Orden</th><th>Orden decimal</th><th>Primer número</th><th>Último número</th></tr> <tr><td><i>Yax Pasaj Chan Yopaat</i></td><td>Hijo</td><td><i>-YOQ/-NIYOQ</i></td><td>Unidad</td><td><b>0</b></td><td><b>9</b></td></tr> <tr><td><i>K’ahk’ Yipyaj Chan K’awiil</i></td><td>Padre</td><td><i>CHUNKA</i></td><td>Decena</td><td><b>10</b></td><td><b>99</b></td></tr> <tr><td><i>Waxaklajuun Ubaah K’awiil</i></td><td>Abuelo</td><td><i>PACHAQ</i></td><td>Centena</td><td><b>100</b></td><td><b>999</b></td></tr> <tr><td><i>K’ahk Uti’ Witz’ K’awiil</i></td><td>Bisabuelo</td><td><i>WARANQA</i></td><td>Unidad de Mil</td><td><b>1,000</b></td><td><b>9,999</b></td></tr> <tr><td><i>Butz’ Chan</i></td><td>Trisabuelo</td><td><i>HUNU</i></td><td>Decena de Mil</td><td><b>10,000</b></td><td><b>99,999</b></td></tr> <tr><td><i>Tzi B’alam</i></td><td>Tetrabuelo</td><td>&nbsp;</td><td>Centena de Mil</td><td><b>100,000</b></td><td><b>999,999</b></td></tr> <tr><td>&nbsp;</td><td>Pentabuelo</td><td>&nbsp;</td><td>Unidad de Millón</td><td><b>1,000,000</b></td><td><b>9,999,999</b></td></tr> <tr><td><i>Wi’ Yohl K’inich</i></td><td>Hexabuelo</td><td>&nbsp;</td><td>Decena de Millón</td><td><b>10,000,000</b></td><td><b>99,999,999</b></td></tr> <tr><td><i>Bahlam Nehn</i></td><td>Heptabuelo</td><td>&nbsp;</td><td>Centena de Millón</td><td><b>100,000,000</b></td><td><b>999,999,999</b></td></tr> <tr><td>&nbsp;</td><td>Octabuelo</td><td>&nbsp;</td><td>Unidad de Mil Millón</td><td><b>1,000,000,000</b></td><td><b>9,999,999,999</b></td></tr> </table></p>",
               "source": null,
               "date_time": null,
               "isTable": false,
