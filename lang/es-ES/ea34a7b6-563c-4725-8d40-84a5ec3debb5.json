            },
            {
               "text": "<p><div class=\"htSlides\"><div class=\"htSlide\"><div class=\"htSlideCounter\">1 / 4</div><img class=\"imgGameSize\" id=\"imgBRES140\" onclick=\"htImageZoom('imgBRES140', '0%')\"><div class=\"htSlideCaption\">Nesta carta, Cristóvão Colombo explicitamente fala de ilhas povoadas com inúmeras pessoas.</div></div><div class=\"htSlide\"><div class=\"htSlideCounter\">2 / 4</div><img class=\"imgGameSize\" id=\"imgLL\" onclick=\"htImageZoom('imgLL', '0%')\"><div class=\"htSlideCaption\">Parte del inventario de Pedro Dias (<a href=\"#\" onclick=\"htCleanSources(); htFillPrimarySource('3a98a6a5-5261-4d8a-b10b-05f7ff97b790'); return false;\">Inventários e Testamentos, <span class=\"htdate\"></span>, Volume 20, pp. 56 </a>).</div></div><div class=\"htSlide\"><div class=\"htSlideCounter\">3 / 4</div><img class=\"imgGameSize\" id=\"imgPD\" onclick=\"htImageZoom('imgPD', '0%')\"><div class=\"htSlideCaption\">Antártica. © Mapswire (<htcite0>).</div></div><div class=\"htSlide\"><div class=\"htSlideCounter\">4 / 4</div><img class=\"imgGameSize\" id=\"Experiment\" onclick=\"htImageZoom('Experiment', '0%')\"><div class=\"htSlideCaption\"></div></div><i class=\"fa-solid fa-chevron-left htSlidePrev\" onclick=\"htPlusDivs(-1);\"></i><i class=\"fa-solid fa-chevron-right htSlideNext\" onclick=\"htPlusDivs(1);\"></i></div></p>",
