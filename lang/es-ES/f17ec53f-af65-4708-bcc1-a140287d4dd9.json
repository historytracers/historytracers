            {
               "text": "<p><table id=\"yupana70\" class=\"tawapukllay\"><tr><th colspan=\"4\"><i>Yupana</i></th><th>Left Hand</th><th>Right Hand</th><th>Arrows</th></tr> <tr id=\"tf1\"><td id=\"tc1f1\"><span class=\"dot five_dot_c1_up\"></span><span class=\"dot five_dot_c1_center\"></span><span class=\"dot five_dot_c1_bottom\"></span><span class=\"dot five_dot_c2_up\"></span><span class=\"dot five_dot_c2_bottom\"></span></td> <td id=\"tc2f1\"><span class=\"dot three_dot_bottom\"></span><span class=\"dot three_dot_up\"></span><span class=\"dot three_dot_center\"></span></td> <td id=\"tc3f1\"><span class=\"dot two_dot_bottom\"></span> <span class=\"dot two_dot_up\"></span></td> <td id=\"tc4f1\"><span class=\"dot dot_center\"></span></td><td id=\"tc5f1\"><img id=\"leftHandImg7\" onclick=\"htImageZoom('leftHandImg7', '0%')\"  /></td><td id=\"tc6f1\"><img id=\"rightHandImg7\" onclick=\"htImageZoom('rightHandImg7', '0%')\"  /></td><td id=\"tc7f1\"><i class=\"fa-solid fa-arrows-left-right upArrowWithFA\" id=\"traineeUp7\"></i> <i class=\"fa-solid fa-arrows-rotate downArrowWithFA\" style=\"font-size:4em;color:#00f;\" id=\"traineeDown7\"></i></td></tr></table></p><p class=\"desc\"><b>Tabla 2</b>: Movimiento <i>KIMSA</i> inverso representando <i>5 − 1 = 4</i>. CSS inspirado por <htcite0>.</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "48dd9187-7ecc-4f54-a387-d9ecc2497de3",
                     "text": "W3School",
                     "page": "",
                     "date_time": {
