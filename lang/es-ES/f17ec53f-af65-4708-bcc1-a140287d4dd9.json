                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": ""
            },
            {
               "text": "#### *PISQA* (inverso)\n\nEl movimiento *PISQA* inverso se usa cuando tenemos un marcador en la línea superior (valor 10) y necesitamos restar 5. El marcador se baja como un único marcador en la casilla 5 de la línea actual, representando la operación",
               "source": [
                  {
                     "type": 1,
                     "uuid": "a62b520a-f443-4d83-ab51-b99c9a46dab8",
                     "text": "Prem, Dhavit",
                     "page": "pp. 357 - 359",
                     "date_time": {
                        "type": "gregory",
                        "year": "2018",
                        "month": "-1",
                        "day": "-1"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "1bb0274d-dc51-4740-ac62-4d157b06ad88",
                     "text": "History Tracers Team (2024). Yupana (Addition)",
                     "page": "",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
                        "month": "-1",
                        "day": "-1"
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "markdown",
               "PostMention": ":"
            },
            {
               "text": "<center><div class=\"first_steps_reflection_parent\" style=\"background-color: #FFFFFF;\"><div class=\"first_steps_reflection\" style=\"background-color: #FFFFFF;\"><p><math mathsize=\"1.5em\" displaystyle=\"false\"><mn>10</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">−</mo><mn>5</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mn>5</mn></math></p></div></div></center>",
               "source": null,
