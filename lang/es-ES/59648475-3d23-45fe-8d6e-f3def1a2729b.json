                     "uuid": "cd150cb3-20bf-46c2-9327-10a39373e9da",
                     "text": "History Tracers Team",
                     "page": "Caminando y cantando",
                     "date_time": {
                        "type": "gregory",
                        "year": "2026",
                        "month": "",
                        "day": ""
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "8b947b40-dc98-4991-924d-d4356a0f55a8",
                     "text": "History Tracers Team",
                     "page": "Ejercitando con músicas",
                     "date_time": {
