                                                                          }
                                                        }
                                                    ],
                                         "date_time":  null,
                                         "isTable":  false,
                                         "imgdesc":  "",
                                         "format":  "html",
                                         "PostMention":  "."
                                     },
                                     {
                                         "text":  "<h4>Longitud</h4>En matemáticas, la longitud (<b>θ</b>) se expresa con valores de 0 hasta 2π radianes o de 0 a 360 grados. No obstante, cuando trabajamos con coordenadas geográficas, dividimos el globo en dos regiones de 180 grados cada una. La línea que separa estas dos regiones es el <b>Meridiano de Greenwich</b>, definido arbitrariamente en <htdate0> como punto zero en el Observatório Real de Greenwich, en la Inglaterra. Las posiciones a leste de Greenwich son mensuradas como X grados a <b>este</b>, y las posiciones a oeste como X grados a <b>oeste</b>",
                                         "source":  [
                                                        {
                                                            "type":  1,
                                                            "uuid":  "006b21c9-6800-4deb-bb3f-a367dd38b703",
                                                            "text":  "NOAA",
                                                            "page":  "Longitude",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "2024",
                                                                              "month":  "06",
                                                                              "day":  "16"
                                                                          }
                                                        }
                                                    ],
                                         "date_time":  null,
                                         "isTable":  false,
                                         "imgdesc":  "",
                                         "format":  "html",
                                         "PostMention":  "."
                                     },
                                     {
                                         "text":  "<h4>Latitud</h4>La latitud (<b>ϕ</b>) se representa en matemáticas con valores que varian de 0 y π/2 radianes, o de 0 a 90 grados. En coordenadas geográficas, dividimos la Tierra en dos regiones de 90 grados, una para el hemisferio norte y otra para el sur. Sin embargo, en matemáticas, las posiciones al sur del ecuador se representan con valores negativos. A diferencia de la longitud, que tiene su origen en un meridiano, la latitud toma como punto de referencia el ecuador, una línea imaginaria que divide el planeta en dos hemisferios. Las posiciones al norte del ecuador se expresan como \"X grados al <b>norte</b>\", y las del sur, como \"X grados al <b>sur</b>\"",
                                         "source":  [
                                                        {
                                                            "type":  1,
                                                            "uuid":  "72ea1365-bb46-4036-a9e2-7384896e0a28",
                                                            "text":  "NOAA",
                                                            "page":  "Latitude",
                                                            "date_time":  {
