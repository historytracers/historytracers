                        "day": "-1"
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "markdown",
               "PostMention": ""
            },
            {
               "text": "<p><center><div class=\"first_steps_reflection_parent\"><div class=\"first_steps_reflection question_mark\"><i class=\"fa-solid fa-brain\"></i></div><div class=\"first_steps_reflection\"><b>Reflexión 1: Esto ya lo he visto también</b><br /><br />Tanto la Yupana como los ábacos utilizan el cuerpo humano como referencia para la representación de los números. También vimos que ambos realizan sumas de manera semejante para números entre 0 y 9.<br /><br />Cuando la suma de dos números da como resultado un valor mayor que 9, ¿cree usted que los ábacos también efectúan la operación de la misma forma que el método *Yupana Inka Tawa Pukllay*, de Dhavit Prem (<htcite0>; <htcite1>)?</div></div></center></p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "a62b520a-f443-4d83-ab51-b99c9a46dab8",
                     "text": "Prem, Dhavit",
                     "page": "pp. 354 - 363",
                     "date_time": {
                        "type": "gregory",
                        "year": "2018",
                        "month": "-1",
                        "day": "-1"
                     }
                  },
                  {
                     "type": 1,
                     "uuid": "2d2ea4a5-506b-4dbf-aaa4-3a10a8fbbd9c",
