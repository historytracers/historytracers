                                                        {
                                                            "type":  1,
                                                            "uuid":  "11311584-03d0-4c19-a807-28e5aaced8d0",
                                                            "text":  "Kragh, H.",
                                                            "page":  "pp. 5",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "2013",
                                                                              "month":  "",
                                                                              "day":  ""
                                                                          }
                                                        },
                                                        {
                                                            "type":  1,
                                                            "uuid":  "1af85131-52aa-49ee-8f9b-2409eb806900",
                                                            "text":  "Hubble, Edwin",
                                                            "page":  "",
                                                            "date_time":  {
                                                                              "type":  "gregory",
                                                                              "year":  "1929",
                                                                              "month":  "-1",
                                                                              "day":  "-1"
                                                                          }
                                                        }
