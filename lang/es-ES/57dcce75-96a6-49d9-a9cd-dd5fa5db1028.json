            {
               "text": "<p class=\"desc\"><img id=\"imgPlanckHistory\" onclick=\"htImageZoom('imgPlanckHistory', '0%')\" src=\"\" class=\"imgcenter\"/><b>Figura 1</b>: Historia del universo según el modelo Lambda-CDM (<htcite0>).</p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "a1a7c478-9061-4160-ba43-301c081733e9",
                     "text": "©ESA – C. Carreau",
                     "page": "Historia de la formación cósmica",
                     "date_time": {
                        "type": "gregory",
                        "year": "2024",
