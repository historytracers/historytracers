                        "year": "2018",
                        "month": "-1",
                        "day": "-1"
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "markdown",
               "PostMention": ":"
            },
            {
               "text": "<center><div class=\"first_steps_reflection_parent\" style=\"background-color: #FFFFFF;\"><div class=\"first_steps_reflection\" style=\"background-color: #FFFFFF;\"><p><math mathsize=\"1.5em\" displaystyle=\"false\"><mn>1</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mn>2</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mn>3</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mn>0</mn></math></p><p><math mathsize=\"1.5em\" displaystyle=\"false\"><mn>2</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mn>3</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">=</mo><mn>5</mn><mo lspace=\"0.1667em\" rspace=\"0.1667em\">+</mo><mn>0</mn></math></p></div></div></center>",
