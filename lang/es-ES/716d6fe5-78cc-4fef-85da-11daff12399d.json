         "id": "SECTION_prerequisites",
         "text": [
            {
               "text": "<p><span id=\"htZoomImageMsg\"></span></p><p><span id=\"htAgeMsg\"></span></p><p><span id=\"htAmericaAbyaYalaMsg\"></span> (<htcite0>).</p><p style=\"font-style: italic;\" id=\"htChinaZhongguo\"></p><p style=\"font-style: italic;\" id=\"htJapanNipponNihonKoku\"></p>",
               "source": [
                  {
                     "type": 1,
                     "uuid": "160fb48c-1711-491e-a1aa-e1257e7889af",
                     "text": "Porto-Gonçalves, Carlos Walter",
                     "page": "pp. 39-43",
                     "date_time": {
                        "type": "gregory",
                        "year": "2011",
                        "month": "",
                        "day": ""
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
