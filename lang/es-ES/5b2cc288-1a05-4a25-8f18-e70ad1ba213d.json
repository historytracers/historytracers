                        "month": "",
                        "day": ""
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": "."
            },
            {
               "text": "Además de la evidencia material, modelos de expansión genética muestran que podría haber ocurrido una única población migratoria que se expandió por el continente (<htcite0>).",
               "source": [
                  {
                     "type": 0,
                     "uuid": "94372b4a-825c-4b76-a252-625274cb17b4",
                     "text": "Fagundes, N. J. R. et al.",
                     "page": "pp. 587 - 589",
                     "date_time": {
                        "type": "gregory",
                        "year": "2008",
                        "month": "",
                        "day": ""
                     }
                  }
               ],
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "markdown",
               "PostMention": "."
            },
            {
               "text": "<p><center><div class=\"first_steps_reflection_parent\"><div class=\"first_steps_reflection question_mark\"><i class=\"fa-solid fa-brain\"></i></div><div class=\"first_steps_reflection\"><b>Reflexión 3: ¿Todo resuelto?</b><br /><br />Tenemos un modelo arqueológico que posee datos recolectados en diferentes partes del continente.<br /><br />Tenemos un modelo genético que muestra que es posible la ocurrencia de una sola migración por todo el continente.<br /><br />Por lo tanto, concluimos que, si juntamos los dos, resolveremos todas las cuestiones sobre la llegada de los humanos a <i>Abya Yala</i> (América).<br /><br />¿Puedes imaginar escenarios que podrían invalidar la conclusión anterior?</div></div></center></p>",
               "source": null,
               "date_time": null,
               "isTable": false,
               "imgdesc": "",
               "format": "html",
               "PostMention": "."
            }
